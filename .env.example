DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True

# Used only when DEBUG=False (production)
DATABASE_URL=postgresql://user:pass@localhost:5432/tradingagent
REDIS_URL=redis://localhost:6379/0

GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_PROVIDER=gemini-or-claude

# OHLCV data source for backtesting/screening: "yfinance" (default, global symbols)
# or "upstox" (NSE/BSE only; symbols like "RELIANCE.NS" are resolved to Upstox
# instrument keys automatically). See apps/backtests/upstox_client.py.
DATA_PROVIDER=yfinance

# Required only when DATA_PROVIDER=upstox. Upstox access tokens are generated via
# the OAuth login flow and expire daily around 3:30am IST — this needs refreshing
# every day (e.g. via a scheduled login script) for production use.
UPSTOX_ACCESS_TOKEN=
